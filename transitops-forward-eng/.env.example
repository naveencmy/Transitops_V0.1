# TransitOps Environment Variables
# Copy to .env and fill in values

# ─── Backend ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://username:postgres@localhost:5432/transitops_db
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Neon PostgreSQL ────────────────────────────────────────
# Get from: https://console.neon.tech
# Use the pooler endpoint for Lambda compatibility
# NEON_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/transitops

# ─── AWS ────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/transitops-deploy-role

# ─── SAM/CloudFormation ─────────────────────────────────────
# SAM_STACK_NAME=transitops-backend
# CLOUDFRONT_DISTRIBUTION_ID=E1234ABCDEF
# S3_BUCKET=transitops-frontend

# ─── Frontend ───────────────────────────────────────────────
# VITE_API_BASE_URL=https://abc123.execute-api.us-east-1.amazonaws.com/prod
